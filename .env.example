# Server
PORT=3000

# Victron Integration
VICTRON_FEED_URL=https://www.victronenergy.com/api/v1/products?format=xml
VICTRON_FETCH_TIMEOUT_MS=30000

# Database
DB_PATH=./data/optigrid.db

# Admin sync key (set to protect the POST /api/victron/sync endpoint)
ADMIN_SYNC_KEY=

# CRM Admin
CRM_PASSWORD=your-secure-password
SESSION_SECRET=random-session-secret

# Email (Resend) — contact form notifications
# Get a key at https://resend.com — leave blank to log submissions only (MVP fallback)
RESEND_API_KEY=
